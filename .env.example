# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Gere uma chave secreta em: https://djecrety.ir/
SECRET_KEY=django-insecure-troque-esta-chave-por-uma-segura

# False em produção, True só para desenvolvimento local
DEBUG=False

# Coloque seu domínio do PythonAnywhere (ex: seuusuario.pythonanywhere.com)
ALLOWED_HOSTS=seuusuario.pythonanywhere.com,localhost,127.0.0.1
